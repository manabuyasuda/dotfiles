      "Bash(ncu --packageFile*)",
      "Bash(ncu --reject*)",
      "Bash(ncu --dep*)",
      "Bash(ncu --packageManager*)",
      "Bash(bundle-phobia*)",
      "Bash(axe*)",
      "Bash(firebase list*)",
      "Bash(firebase functions:list*)",
      "Bash(firebase hosting:channel:list*)",
      "Bash(vercel ls*)",
      "Bash(vercel list*)",
      "Bash(vercel inspect*)",
      "Bash(vercel logs*)",
      "Bash(vercel whoami*)",
      "Bash(vercel projects*)",
      "Bash(lhci collect*)",
      "Bash(lhci assert*)",
      "Bash(lhci open*)",
      "Bash(lhci healthcheck*)",
      "Bash(redocly lint*)",
      "Bash(redocly stats*)",
      "Bash(redocly bundle*)",
