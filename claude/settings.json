      "Bash(gh repo view*)",
      "Bash(gh repo list*)",
      "Bash(gh api repos*)",
      "Bash(gh api notifications*)",
      "Bash(gh api graphql*)",
      "Bash(gh api user*)",
      "Bash(gh search*)",
      "Bash(gh dash*)",
      "Bash(gh f)",
      "Bash(gh s)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git stash list*)",
      "Bash(git branch --show-current*)",
      "Bash(git diff*)",
      "Bash(git show*)",
