      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_network_requests",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_close",
      "Skill(x-*)"
    ],
    "deny": [
      "Glob(**/.env*)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Bash(cat **/.env*)",
      "Read(~/.ssh/*)",
      "Bash(cat ~/.ssh/*)",
      "Read(~/.aws/*)",
      "Bash(cat ~/.aws/*)",
      "Read(~/.gcloud/*)",
      "Bash(cat ~/.gcloud/*)",
      "Read(~/.config/gcloud/*)",
      "Bash(cat ~/.config/gcloud/*)",
      "Read(~/.azure/*)",
      "Bash(cat ~/.azure/*)",
      "Read(~/.kube/config)",
      "Bash(cat ~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Bash(cat ~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Bash(cat ~/.npmrc)",
      "Read(~/.netrc)",
      "Bash(cat ~/.netrc)",
      "Read(~/.config/gh/*)",
      "Bash(cat ~/.config/gh/*)",
      "Bash(security find-generic-password*)",
      "Bash(gh repo delete*)",
      "Bash(gh secret set*)",
      "Bash(gh secret delete*)",
      "Bash(gh secret remove*)",
      "Bash(gh api --method DELETE*)",
      "Bash(gh api -X DELETE*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(bun publish*)",
      "Bash(op item edit*)",
      "Bash(bw item edit*)",
      "Bash(aws secretsmanager put-secret-value*)",
      "Bash(gcloud secrets versions add*)",
      "Bash(vault kv put*)",
      "Bash(doppler secrets set*)",
      "Bash(infisical secrets set*)",
      "Bash(vercel env add*)",
      "Bash(netlify env:set*)",
      "Bash(firebase functions:config:set*)",
      "Bash(supabase secrets set*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-start/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/worktree/create.sh"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/worktree/remove.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-tool-use/branch-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-tool-use/file-protect.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-tool-use/mermaid-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-tool-use/bash-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-tool-use/dangerous-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-tool-use/push-to-main-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-tool-use/check-gh-account.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-tool-use/format.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-tool-use/install.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-tool-use/test.sh",
            "timeout": 90
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-tool-use/typecheck.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-tool-use/mermaid-guard.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notification/notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notification/notify.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "language": "日本語のですます調で応答します。文は述語で終え、名詞止めはしません。漢語の複合名詞（「未取得」「定義外」「未知値」など）は動詞句に展開します（「取得できていない」「対応していない」など）。名詞を直接つなげず、助詞（の・による・に関する等）または活用形（した・する・な等）で修飾関係を明示します。冗長な表現（「することができます」「する必要があります」など）、誇張・ハイプ表現（「革命的」「究極の」など）、評価を上乗せするだけで実質の情報を加えない表現、深みを演出するだけのフレーズ（「本質的には」「真に重要なのは」など）、根拠のない楽観的な結語（「今後の発展が期待されます」など）は使いません。",
  "effortLevel": "xhigh",
  "showThinkingSummaries": true,
  "theme": "dark"
}
