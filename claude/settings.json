      "Bash(semgrep*)",
      "Bash(type-coverage*)",
      "Bash(tree*)",
      "Bash(ncu)",
      "Bash(ncu --filter*)",
      "Bash(ncu --format*)",
      "Bash(ncu --target*)",
      "Bash(ncu --global*)",
      "Bash(ncu -g*)",
